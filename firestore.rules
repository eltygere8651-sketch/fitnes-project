rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['email', 'displayName', 'photoURL', 'lastLogin'])
      );
      
      function isValidUser(data) {
        return data.keys().hasAny(['email', 'lastLogin']);
      }
    }

    // 2. User Playlists (Acceso Público para Lectura)
    match /{path=**}/playlists/{playlistId} {
      allow list, get: if true; // Cualquier persona puede ver cualquier playlist
      
      // Pero solo el dueño puede modificar (asumiendo que path contiene el userId)
      allow create, update, delete: if isSignedIn() && request.auth.uid == getOwnerIdFromPath(path);

      function getOwnerIdFromPath(p) {
        // Lógica simple: si el path es /users/XYZ/playlists, extraemos XYZ
        return p[1]; 
      }
    }

    function isValidPlaylist(data) {
      return data.keys().hasAll(['name', 'ownerId', 'tracks', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() <= 300 &&
             data.ownerId == request.auth.uid &&
             data.tracks is list && data.tracks.size() <= 100 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }
  }
}
