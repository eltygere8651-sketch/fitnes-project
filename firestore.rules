rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Solo permitimos al Administrador Maestro realizar modificaciones
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "eltygere8651@gmail.com";
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Profiles
    match /users/{userId} {
      // El admin puede ver perfiles (o el propio usuario si existiera)
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // SOLO el admin puede crear o actualizar perfiles (Registros Bloqueados para otros)
      allow create, update: if isAdmin() && (request.auth.uid == userId);
      
      // Permitimos que el admin se borre si fuera necesario (opcional)
      allow delete: if isAdmin() && (request.auth.uid == userId);
    }

    // 2. Playlists (Acceso Público de Lectura, Escritura SOLO Admin o con Clave)
    match /users/{userId}/playlists/{playlistId} {
      // Lectura pública
      allow list, get: if true; 
      
      // Creación permitida si el documento tiene la clave secreta correcta o es el admin
      allow create: if (request.resource.data.adminSecret == "ho82788278") || isAdmin();
      
      // Escritura restringida únicamente al Admin
      allow update, delete: if isAdmin() && (request.auth.uid == userId);
    }

    // Regla de respaldo para cualquier subcolección de playlist si existiera
    match /{path=**}/playlists/{playlistId} {
      allow list, get: if true;
      allow create: if (request.resource.data.adminSecret == "ho82788278") || isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
