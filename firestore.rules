rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Solo permitimos al Administrador Maestro realizar modificaciones
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "eltygere8651@gmail.com";
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Profiles
    match /users/{userId} {
      // El usuario puede leer su propio perfil, admin puede leer todos
      allow get, list: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // Permitir que el usuario cree su propio perfil inicial
      allow create: if isSignedIn() && (request.auth.uid == userId);
      
      // Permitir que el usuario actualice su perfil, protegiendo campos sensibles
      allow update: if isAdmin() || (
        isSignedIn() && request.auth.uid == userId &&
        (!request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['trialStart', 'subscriptionEnd', 'plan', 'role']))
      );
      
      allow delete: if isAdmin() && (request.auth.uid == userId);
    }

    // 2. Playlists (Acceso Público de Lectura, Escritura SOLO Admin o con Clave)
    match /users/{userId}/playlists/{playlistId} {
      // Lectura pública
      allow list, get: if true; 
      
      // Creación permitida si el documento tiene la clave secreta correcta o es el admin
      allow create: if (request.resource.data.adminSecret == "ho82788278") || isAdmin();
      
      // Escritura permitida al Admin, al Dueño, o a quien conozca la clave (si el doc la tiene)
      allow update, delete: if isAdmin() || 
                             (isSignedIn() && (request.auth.uid == userId || existing().adminSecret == "ho82788278"));
    }

    // Regla de respaldo para cualquier subcolección de playlist si existiera
    match /{path=**}/playlists/{playlistId} {
      allow list, get: if true;
      allow create: if (request.resource.data.adminSecret == "ho82788278") || isAdmin();
      allow update, delete: if isAdmin() || 
                             (isSignedIn() && (request.auth.uid == userId || (resource != null && resource.data.adminSecret == "ho82788278")));
    }
  }
}
